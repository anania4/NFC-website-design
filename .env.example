# Django Settings
# Generate a new secret key for production using: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here-replace-with-actual-secret-key

# Set to False in production, True for development
DEBUG=False

# Comma-separated list of allowed hostnames/domains
# Example: yourdomain.com,www.yourdomain.com,subdomain.yourdomain.com
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Chapa Payment Gateway Configuration
# Get these keys from your Chapa dashboard at https://dashboard.chapa.co
CHAPA_SECRET_KEY=your-chapa-secret-key-here
CHAPA_PUBLIC_KEY=your-chapa-public-key-here

# Security Settings
# Set to True in production to redirect all HTTP requests to HTTPS
# Set to False in development or if SSL is handled by a reverse proxy
SECURE_SSL_REDIRECT=True

# Optional: Database Configuration (if using PostgreSQL in production)
# DATABASE_URL=postgresql://user:password@localhost/dbname
